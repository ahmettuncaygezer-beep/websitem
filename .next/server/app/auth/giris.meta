{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/giris/layout,_N_T_/auth/giris/page,_N_T_/auth/giris"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/giris/__PAGE__",
    "/auth/giris",
    "/auth",
    "/_index",
    "/_head"
  ]
}