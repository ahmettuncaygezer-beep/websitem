{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?\\/admin(?:\\/((?:[^\\/#\\?]+?)(?:\\/(?:[^\\/#\\?]+?))*))?(\\.json)?[\\/#\\?]?$",
          "originalSource": "/admin/:path*"
        }
      ]
    },
    "/api/chat": {
      "maxDuration": 30
    },
    "/api/style-quiz": {
      "maxDuration": 30
    },
    "/api/visual-search": {
      "maxDuration": 30
    }
  }
}